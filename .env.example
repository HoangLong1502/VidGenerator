# Gemini API key for script generation (free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Image generation provider:
# - `gemini` (uses GEMINI_API_KEY; may require paid access for image generation)
# - `a1111` (free, uses your local Automatic1111 Stable Diffusion)
# - `pollinations` (free hosted image generation, no API key)
IMAGE_PROVIDER=pollinations

# Automatic1111 Stable Diffusion (free/local)
SD_API_URL=http://127.0.0.1:7860
SD_WIDTH=576
SD_HEIGHT=1024
SD_STEPS=28
SD_CFG_SCALE=7
# SD_SAMPLER_NAME=DPM++ 2M Karras
# SD_NEGATIVE_PROMPT="text, subtitles, captions, watermark, logo, signature, blurry, low-res, artifacts"

# Pollinations (free hosted, keyless — image.pollinations.ai)
# Try: zimage (default, sharp), sana, flux, turbo, stable-diffusion
POLLINATIONS_MODEL=zimage
POLLINATIONS_FALLBACK_MODELS=sana,flux,turbo
# Let Pollinations rewrite the prompt for stronger results (set false if style drifts)
POLLINATIONS_ENHANCE=true
POLLINATIONS_WIDTH=720
POLLINATIONS_HEIGHT=1280
# Optional cap for Pollinations only (omit to use MAX_BG_IMAGES). Lower if rate-limited.
# POLLINATIONS_MAX_IMAGES=12
POLLINATIONS_BETWEEN_MS=4000
POLLINATIONS_MAX_RETRIES=6
POLLINATIONS_FETCH_TIMEOUT_MS=90000

# Gemini model for generating images (used only if IMAGE_PROVIDER=gemini)
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# Gemini images API version: try "v1beta" (default in SDK) for image models.
GEMINI_IMAGE_API_VERSION=v1beta
GEMINI_SCRIPT_MODEL=gemini-flash-latest
# Second model used if the first response is unusable (separate free-tier quota bucket).
GEMINI_SCRIPT_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest
# Script token saver knobs (used by /api/generate-video)
# Keep user topic short before sending to Gemini.
GEMINI_SCRIPT_TOPIC_MAX_CHARS=240
# Smaller defaults reduce JSON truncation; raise for longer videos if your tier allows.
GEMINI_SCRIPT_MIN_LINES=22
GEMINI_SCRIPT_MAX_LINES=34
GEMINI_SCRIPT_LINE_MAX_CHARS=96
GEMINI_SCRIPT_MAX_OUTPUT_TOKENS=10240
# Trims "thinking" output on models that support thinkingConfig (saves candidate tokens for JSON).
# Set to "false" if generateContent returns 400 about thinkingConfig.
GEMINI_SCRIPT_DISABLE_THINKING=true
# Max chars of broken model output sent into the repair prompt (keeps repair request smaller).
# GEMINI_SCRIPT_REPAIR_CONTENT_MAX=14000
# When Gemini returns 429, wait and retry (uses RetryInfo when present; caps wait per step).
# GEMINI_SCRIPT_429_MAX_RETRIES=3
# GEMINI_SCRIPT_429_MAX_WAIT_MS=48000
# Limit number of generated background images per video (more scenes for longer scripts)
MAX_BG_IMAGES=20
# Global visual style preset for generated images (digital_art is default)
IMAGE_STYLE_PRESET=digital_art
# 1K is cheapest; 2K is more detailed (depends on the selected model support)
GEMINI_IMAGE_SIZE=1K

# YouTube: create OAuth 2.0 credentials in Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3, create OAuth client (Web application), add redirect URI:
#   http://localhost:3001/api/youtube/oauth2callback
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret

# Redirect URI (default: http://localhost:3001/api/youtube/oauth2callback)
# YOUTUBE_REDIRECT_URI=http://localhost:3001/api/youtube/oauth2callback

# TikTok: create app at https://developers.tiktok.com/
# In app: add product "Login Kit", then add Redirect URI (must match exactly).
# TikTok bắt buộc HTTPS. Chạy: npm run tiktok:tunnel (cần cài ngrok), rồi điền URL nhận được:
#   TIKTOK_REDIRECT_URI=https://YOUR_SUBDOMAIN.ngrok-free.app/api/tiktok/oauth2callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
# TIKTOK_REDIRECT_URI=http://localhost:3001/api/tiktok/oauth2callback

# Tenor API key (v2) for GIF/MP4 backgrounds (https://developers.google.com/tenor/guides/quickstart)
TENOR_API_KEY=your_tenor_api_key

# GIPHY API key for GIF/MP4 backgrounds (https://developers.giphy.com/)
GIPHY_API_KEY=your_giphy_api_key

# Set which provider to use for backgrounds: 'giphy' or 'tenor'
GIF_SOURCE=giphy

# Edge TTS worker URL (VidGenerator proxies /api/tts here)
# TTS_SERVER_URL=http://127.0.0.1:8001

# Voice (TTS): start Edge TTS server in F:\coqui-tts-server:
#   .venv\Scripts\activate && uvicorn server:app --host 127.0.0.1 --port 8001
# Edge neural voice id (default: Vietnamese female). Official vi-VN: HoaiMy (nữ), NamMinh (nam).
# For Vietnamese, Edge only exposes those two neural voices; “more human” is mostly prosody — tune on the Python server:
#   TTS_RATE (e.g. +2%, +5%, or off), TTS_PITCH (e.g. +1Hz) in F:\coqui-tts-server before uvicorn.
TTS_VOICE=vi-VN-HoaiMyNeural
# Optional: voice id sent from the browser (Vite). Defaults to HoaiMy if unset.
# VITE_TTS_VOICE=vi-VN-HoaiMyNeural
# Longer lines need more time per segment from the Edge TTS worker.
TTS_PROXY_TIMEOUT_MS=25000
TTS_PROXY_MAX_RETRIES=2

# Raise if /api/generate-images returns huge base64 payloads (default 64mb in code).
# JSON_BODY_LIMIT=64mb

PORT=3001
